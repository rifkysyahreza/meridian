# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ─────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Runtime selector (default: openai-chat)
LLM_RUNTIME=openai-chat

# Option A: OpenRouter / other OpenAI-compatible providers
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your_provider_key_if_not_using_OPENROUTER_API_KEY
# LLM_MODEL=your-model-name

# Option B: OpenClaw/Codex local bridge (MVP)
# Uses the locally installed `openclaw` CLI and its embedded agent runtime.
# LLM_RUNTIME=openclaw-codex
# OPENCLAW_AGENT_COMMAND=openclaw
# OPENCLAW_AGENT_TIMEOUT_MS=300000
# OPENCLAW_AGENT_SESSION_PREFIX=meridian-openclaw-bridge
# OPENCLAW_AGENT_EXTRA_ARGS=--thinking low

# Option C: LM Studio / Ollama / local OpenAI-compatible server
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-name-from-lmstudio

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=info
